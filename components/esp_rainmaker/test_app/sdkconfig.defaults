# Task watchdog: do not check idle task
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=n
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=n

# Run all tests on boot (no interactive menu)
CONFIG_UNIT_TEST_RUN_ALL_AUTO=y

# Unity test framework configuration
CONFIG_UNITY_ENABLE_FLOAT=y
CONFIG_UNITY_ENABLE_DOUBLE=y
CONFIG_UNITY_ENABLE_64BIT=y
CONFIG_UNITY_ENABLE_COLOR=y
CONFIG_UNITY_ENABLE_IDF_TEST_RUNNER=y
CONFIG_UNITY_ENABLE_FIXTURE=y
CONFIG_UNITY_ENABLE_BACKTRACE_ON_FAIL=y

# ESP RainMaker configuration
CONFIG_ESP_MAIN_TASK_STACK_SIZE=7168
CONFIG_ESP_RMAKER_TASK_STACK=4096
CONFIG_ESP_RMAKER_WORK_QUEUE_TASK_STACK=4096
CONFIG_ESP_RMAKER_WORK_QUEUE_TASK_PRIORITY=5

# ESP RainMaker component specific configuration
CONFIG_ESP_RMAKER_SELF_CLAIM=y
CONFIG_ESP_RMAKER_CLAIM_TYPE_RANDOM=y
# Disable challenge response so node init works when device has no claim data (CI/local without claim flash)
CONFIG_ESP_RMAKER_ENABLE_CHALLENGE_RESPONSE=n
CONFIG_ESP_RMAKER_MQTT_GLUE_ENABLED=y
CONFIG_ESP_RMAKER_LOCAL_CTRL_AUTO_ENABLE=y

# Compiler and partition table
CONFIG_COMPILER_OPTIMIZATION_DEFAULT=y
CONFIG_PARTITION_TABLE_CUSTOM=y
#CONFIG_PARTITION_TABLE_SINGLE_APP=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
